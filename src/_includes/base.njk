<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title and title != "Home" %}{{ title }} — {% endif %}Backyard Thru Hike</title>
<meta name="description" content="{{ description or 'Backyard Thru Hike — finding the national park in the space you already have.' }}">
<link rel="stylesheet" href="/styles.css">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
</head>
<body>

<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/">
      <img src="/logo.svg" alt="" aria-hidden="true" class="brand-logo" width="36" height="36">
      <span>
        <span class="brand-name">{{ siteconfig.brand_name }}</span>
        <span class="brand-sub">{{ siteconfig.brand_tagline }}</span>
      </span>
    </a>
    <nav class="main-nav" aria-label="Primary">
      <ul>
        {% for item in siteconfig.nav %}
        <li><a href="{{ item.url }}" {% if page.url == item.url or (item.url != "/" and item.url in page.url) %}aria-current="page"{% endif %}>{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>

{{ content | safe }}

<footer class="site-footer">
  <a id="seasonal-ticker" class="seasonal-ticker" href="https://grownative.org/learn/native-landscape-care-calendar/" target="_blank" rel="noopener noreferrer">
    <span class="ticker-season"></span>
    <span class="ticker-slide"></span>
  </a>
</footer>

<script src="/seasonal-ticker.js"></script>
</body>
</html>
