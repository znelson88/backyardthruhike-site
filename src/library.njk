title: Library
permalink: /library/
---

<section class="hero" style="padding: var(--space-4) 0 var(--space-3);">
  <svg class="contours" viewBox="0 0 1080 200" preserveAspectRatio="none" aria-hidden="true">
    <path d="M-20,160 C150,140 250,180 400,150 C550,120 650,160 820,140 C950,120 1000,150 1100,130" fill="none" stroke="#C7BC9C" stroke-width="2"/>
    <path d="M-20,180 C150,160 250,200 400,170 C550,140 650,180 820,160 C950,140 1000,170 1100,150" fill="none" stroke="#C7BC9C" stroke-width="1.5"/>
  </svg>
  <div class="wrap">
    <p class="hero-eyebrow">Library</p>
    <h1>A small collection,<br>by request</h1>
    <p class="lede">Field guides, naturalist references, and a few books on how people relate to local nature — shared with people who are interested in looking more carefully at the spaces around them. Access is by request and reviewed individually.</p>
  </div>
</section>

<main>
  <section class="wrap">
    <div class="library-panel">

      <div>
        <span class="trail-status"><span class="dot" aria-hidden="true"></span> Access not yet open</span>
        <h2 style="margin-top: 0.75rem;">Request an invite</h2>
        <p style="max-width: 56ch; color: var(--color-ink-soft);">
          Tell me a little about yourself and what draws you to local nature. I read every request personally —
          once approved, I'll set up access and send it your way.
        </p>
      </div>

      <form class="request-form" action="mailto:you@backyardthruhike.com" method="post" enctype="text/plain">
        <div>
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div>
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div>
          <label for="note">A bit about why you'd like access</label>
          <textarea id="note" name="note" rows="4"></textarea>
        </div>
        <button type="submit" class="btn">Send request</button>
      </form>

    </div>
  </section>
</main>
