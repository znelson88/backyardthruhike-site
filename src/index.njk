---
layout: base.njk
title: Home
---

<section class="hero"{% if homepage.hero_bg_color %} style="background:{{ homepage.hero_bg_color }}"{% endif %}>
  <svg class="contours" viewBox="0 0 1080 360" preserveAspectRatio="none" aria-hidden="true">
    <path d="M-20,300 C150,260 250,340 400,290 C550,240 650,310 820,270 C950,240 1000,280 1100,250" fill="none" stroke="#C7BC9C" stroke-width="2"/>
    <path d="M-20,330 C150,290 250,370 400,320 C550,270 650,340 820,300 C950,270 1000,310 1100,280" fill="none" stroke="#C7BC9C" stroke-width="2"/>
    <path d="M-20,270 C150,230 250,310 400,260 C550,210 650,280 820,240 C950,210 1000,250 1100,220" fill="none" stroke="#C7BC9C" stroke-width="1.5"/>
    <path d="M-20,240 C150,200 250,280 400,230 C550,180 650,250 820,210 C950,180 1000,220 1100,190" fill="none" stroke="#C7BC9C" stroke-width="1.5"/>
  </svg>
  <div class="wrap">
    <p class="hero-eyebrow">{{ homepage.eyebrow }}</p>
    <h1>{{ homepage.headline | replace("\n", "<br>") | safe }}</h1>
    <p class="lede">{{ homepage.lede }}</p>
    <p style="margin-top: 2rem;">
      <a class="btn" href="{{ homepage.cta_primary_url }}">{{ homepage.cta_primary_label }}</a>
      <a class="btn btn-outline" href="{{ homepage.cta_secondary_url }}" style="margin-left: 0.75rem;">{{ homepage.cta_secondary_label }}</a>
    </p>
    {% if homepage.hero_image %}
    <div class="page-image-wrap" style="margin-top: var(--space-4); margin-bottom: 0;">
      <img class="page-image" src="{{ homepage.hero_image }}" alt="{{ homepage.hero_image_alt or '' }}">
    </div>
    {% endif %}
  </div>
</section>

<svg class="elevation-divider wrap" viewBox="0 0 1080 56" preserveAspectRatio="none" aria-hidden="true">
  <polyline points="0,40 90,30 180,42 270,18 360,34 450,10 540,28 630,16 720,36 810,22 900,30 990,12 1080,26"
    fill="none" stroke="#C1542C" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
</svg>

