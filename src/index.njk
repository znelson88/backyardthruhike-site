---
layout: base.njk
title: Home
---

<!-- ===================== HERO ===================== -->
<section class="hero">
  <svg class="hero-svg" viewBox="0 0 1440 760" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
    <defs>
      <linearGradient id="bthSky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" style="stop-color:var(--sky-top)"></stop>
        <stop offset="1" style="stop-color:var(--sky-bottom)"></stop>
      </linearGradient>
    </defs>
    <rect x="0" y="0" width="1440" height="760" fill="url(#bthSky)"></rect>
    <circle cx="1175" cy="158" r="92" style="fill:var(--sun)" opacity="0.16"></circle>
    <circle cx="1175" cy="158" r="56" style="fill:var(--sun)" opacity="0.9"></circle>
    <g style="stroke:var(--ridge-near)" fill="none" opacity="0.13" stroke-width="1.4">
      <path d="M-40,250 C 240,200 520,210 760,234 C 1020,260 1260,238 1500,250"></path>
      <path d="M-40,300 C 260,256 540,266 780,288 C 1040,312 1280,292 1500,302"></path>
      <path d="M-40,196 C 220,150 480,160 720,182 C 980,206 1240,186 1500,196"></path>
    </g>
    <path d="M0,330 C 220,288 380,320 600,300 C 820,280 980,322 1200,302 C 1320,291 1400,312 1440,304 L1440,760 L0,760 Z" style="fill:var(--ridge-far)"></path>
    <path d="M0,420 C 240,378 420,420 640,398 C 880,374 1040,422 1260,400 C 1360,389 1410,410 1440,404 L1440,760 L0,760 Z" style="fill:var(--ridge-mid)"></path>
    <path d="M0,512 C 220,478 440,520 680,496 C 920,472 1080,520 1300,498 C 1370,491 1410,506 1440,502 L1440,760 L0,760 Z" style="fill:var(--ridge-near)"></path>
    <path d="M0,604 C 260,576 480,612 720,590 C 960,568 1160,612 1380,592 L1440,600 L1440,760 L0,760 Z" style="fill:var(--ridge-fore)"></path>
  </svg>

  <div class="hero-content">
    <div class="hero-inner">
      <div class="location-pill">
        <span class="location-pill__dot" aria-hidden="true"></span>
        PLATTSBURG, MO &middot; 39.5656&deg;N
      </div>
      <h1>Find the trail in your own backyard.</h1>
      <p class="hero-lede">A field journal and lending library for the people of Plattsburg &mdash; for anyone who wants to find a little wildness in the ordinary ground underfoot. No summit required.</p>
      <div class="hero-ctas">
        <a href="#journal" class="btn btn-primary">Read the Journal &rarr;</a>
        <a href="#library" class="btn btn-secondary">Visit the Corner Library</a>
      </div>
    </div>
  </div>
</section>

<!-- ===================== ELEVATION DIVIDER ===================== -->
<div class="elevation-divider">
  <svg viewBox="0 0 1440 70" preserveAspectRatio="none" style="display:block;width:100%;height:62px;" aria-hidden="true">
    <path d="M0,52 L120,40 L210,58 L320,30 L430,46 L560,18 L660,42 L790,26 L920,50 L1030,32 L1160,54 L1280,36 L1380,52 L1440,42 L1440,70 L0,70 Z" style="fill:var(--accent)"></path>
    <path d="M0,52 L120,40 L210,58 L320,30 L430,46 L560,18 L660,42 L790,26 L920,50 L1030,32 L1160,54 L1280,36 L1380,52 L1440,42" fill="none" style="stroke:var(--accent)" stroke-width="2" opacity="0.55"></path>
  </svg>
</div>

<!-- ===================== JOURNAL ===================== -->
<section id="journal" class="journal-section">
  <div class="section-wrap">
    <div class="section-header">
      <div>
        <div class="section-eyebrow">FIELD JOURNAL</div>
        <h2>Lately, on the trail</h2>
      </div>
      <a href="/blog/" class="all-entries-link">All entries &rarr;</a>
    </div>

    <div class="card-grid">
      {% for post in journalposts %}
      <article class="journal-card">
        <div class="card-thumb" aria-hidden="true"></div>
        <div class="card-body">
          <div class="card-tags">
            {% for tag in post.tags %}
            <span class="tag-chip">{{ tag }}</span>
            {% endfor %}
          </div>
          <h3 class="card-title">{{ post.title }}</h3>
          <p class="card-excerpt">{{ post.excerpt }}</p>
          <div class="card-meta">
            <span>{{ post.date }}</span>
            <span class="card-meta__bullet" aria-hidden="true">&bull;</span>
            <span>{{ post.read }}</span>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===================== CORNER LIBRARY ===================== -->
<section id="library" class="library-section">
  <div class="section-wrap library-grid">
    <div class="library-image-wrap">
      <div class="library-badge" aria-hidden="true">FREE<br>TO<br>BORROW</div>
      <div class="library-image" role="img" aria-label="Gear shelf — photo coming soon"></div>
    </div>

    <div class="library-content">
      <div class="section-eyebrow">THE CORNER LIBRARY</div>
      <h2>Borrow what you need.<br>Return it when you're done.</h2>
      <p class="library-lede">A shelf of shared gear and well-worn field guides, kept in the front room just off the square downtown. Take a pack for the weekend, a guidebook for the season &mdash; leave it better than you found it.</p>

      <div class="library-items">
        {% for item in libraryitems %}
        <div class="library-item">
          <span class="library-item__name">{{ item.name }}</span>
          <span class="library-item__status library-item__status--{{ item.kind }}">{{ item.status }}</span>
        </div>
        {% endfor %}
      </div>

      <div class="library-actions">
        <a href="/library/" class="btn btn-green">Browse the full library &rarr;</a>
        <span class="library-actions__note">or drop a request in the box on the square.</span>
      </div>
    </div>
  </div>
</section>

<!-- ===================== ABOUT / DEDICATION ===================== -->
<section id="about" class="about-section">
  <div class="about-label">FIELD NOTES &middot; EST. 2026</div>
  <blockquote class="about-quote">
    &ldquo;You don&rsquo;t need a trailhead and a tank of gas. You need ten minutes, a pair of boots, and the willingness to look closely at the ground you already stand on.&rdquo;
  </blockquote>
  <div class="about-dedication">MADE FOR THE PEOPLE OF PLATTSBURG, MO</div>
</section>
